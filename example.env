# Perfil de Prosody: lab (sin TLS obligatorio) o secure (TLS obligatorio)
PROSODY_PROFILE=lab

# Dominio y usuarios de pruebas
XMPP_DOMAIN=localhost
XMPP_EMISOR_USER=emisor
XMPP_RECEPTOR_USER=receptor
XMPP_ADMIN_USER=admin
XMPP_EMISOR_PASS=123
XMPP_RECEPTOR_PASS=123
XMPP_ADMIN_PASS=123

# Host/puerto usados por el runner
XMPP_HOST=prosody
XMPP_PORT=5222
